# === Agentic Drilling Advisory System — Environment Variables ===

# OpenAI API Key (required for GPT-4o / GPT-4o-mini)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Model selection (default: gpt-4o-mini for cost efficiency)
# Options: gpt-4o, gpt-4o-mini, gpt-3.5-turbo
LLM_MODEL=gpt-4o-mini

# Embedding model (default: local sentence-transformers — no API key needed)
# Set to "openai" to use OpenAI embeddings instead
EMBEDDING_PROVIDER=local

# LangSmith tracing (optional — for debugging agent decisions)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-your-key-here
